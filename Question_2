@Entity
@Table(name = "product")
class Product {

    @Id
    @Column(name = "pro_id")
    private int id;

    @Column(name = "name")
    private String name;

    @Column(name = "price")
    private int price;

    public Product() {
    }

    public Product(int pro_id, String name, int price) {
        this.id = pro_id;
        this.name = name;
        this.price = price;
    }

    public int getid() {
        return id;
    }

    public void setCustEId(int id) {
        this.id = id;
    }

    public String getName() {
        return name;
    }

    public void setName(String name) {
        this.name = name;
    }

    public int getPrice() {
        return price;
    }

    public void setPrice(int price) {
        this.price= price;
    }
}
